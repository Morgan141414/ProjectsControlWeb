  "faq": {
    "title": "Часто задаваемые вопросы",
    "subtitle": "Найдите ответы на популярные вопросы о платформе",
    "searchPlaceholder": "Поиск по вопросам...",
    "noResults": "Ничего не найдено",
    "categories": {
      "all": "Все",
      "getting_started": "Начало работы",
      "activity": "Активность",
      "reports": "Отчёты",
      "account": "Аккаунт",
      "admin": "Администрирование",
      "support": "Поддержка"
    },
    "items": {
      "whatIsPlatform": {
        "q": "Что такое QMED и для чего нужна эта платформа?",
        "a": "QMED — это цифровая платформа для управления продуктивностью и мониторинга активности сотрудников. Она позволяет отслеживать рабочие сессии, формировать отчёты, управлять командами и проектами, а также получать AI-аналитику по продуктивности."
      },
      "howToRegister": {
        "q": "Как зарегистрироваться на платформе?",
        "a": "Перейдите на страницу регистрации, укажите ваше полное имя, email и пароль (минимум 8 символов, заглавная и строчная буква, цифра). После регистрации вы сможете создать организацию или присоединиться к существующей."
      },
      "howToJoinOrg": {
        "q": "Как присоединиться к организации?",
        "a": "На дашборде введите код организации, который вам предоставил администратор, и нажмите «Вступить». Ваша заявка будет отправлена администратору на одобрение. После одобрения вы получите доступ ко всем функциям организации."
      },
      "howToCreateOrg": {
        "q": "Как создать свою организацию?",
        "a": "На дашборде нажмите «Создать организацию» и укажите название. После создания вы станете администратором и получите уникальный код для приглашения сотрудников."
      },
      "whatIsActivity": {
        "q": "Что такое отслеживание активности?",
        "a": "Модуль активности позволяет фиксировать рабочие сессии сотрудников. Каждая сессия записывает время начала и окончания работы, устройство и операционную систему. Это помогает вести учёт рабочего времени."
      },
      "howToStartSession": {
        "q": "Как начать рабочую сессию?",
        "a": "Перейдите на страницу «Активность», укажите имя устройства и операционную систему, затем нажмите «Начать сессию». Для завершения нажмите «Завершить сессию». Все ваши сессии сохраняются в истории."
      },
      "canManagerSeeActivity": {
        "q": "Может ли руководитель видеть мою активность?",
        "a": "Да, администраторы организации могут видеть сессии всех участников на вкладке «Сессии организации». Обычные сотрудники видят только свои собственные сессии."
      },
      "whatReportsAvailable": {
        "q": "Какие отчёты доступны на платформе?",
        "a": "Платформа предоставляет: KPI организации и проектов, метрики сессий и пользователей, AI-аналитику продуктивности, а также возможность экспорта отчётов в различных форматах."
      },
      "howToExportReport": {
        "q": "Как экспортировать отчёт?",
        "a": "На странице «Отчёты» перейдите на вкладку «Экспорты», выберите тип отчёта, период и формат (PDF, CSV, JSON), затем нажмите «Создать». Готовый файл появится в истории экспортов."
      },
      "whatIsAiScore": {
        "q": "Что такое AI-оценка продуктивности?",
        "a": "AI-аналитика использует данные об активности для автоматического расчёта оценки продуктивности. Система анализирует паттерны работы, учитывает роль сотрудника и даёт рекомендации по улучшению эффективности."
      },
      "howToChangePassword": {
        "q": "Как изменить пароль?",
        "a": "Перейдите в «Настройки» и воспользуйтесь разделом безопасности. Если вы забыли текущий пароль, используйте функцию «Забыли пароль?» на странице входа."
      },
      "howToEnable2fa": {
        "q": "Как включить двухфакторную аутентификацию?",
        "a": "Перейдите в «Настройки» → «Безопасность» и нажмите «Включить 2FA». Отсканируйте QR-код приложением-аутентификатором (Google Authenticator, Authy и др.) и введите код подтверждения."
      },
      "howToEditProfile": {
        "q": "Как редактировать профиль?",
        "a": "На странице «Профиль» нажмите «Редактировать профиль». Вы можете изменить имя, отчество, биографию, специальность и ссылки на социальные сети."
      },
      "howToManageMembers": {
        "q": "Как управлять участниками организации?",
        "a": "В панели администратора на вкладке «Организация» вы можете просматривать список участников, менять их роли и управлять доступом. Доступные роли: сотрудник, менеджер и администратор."
      },
      "whatArePrivacyRules": {
        "q": "Что такое правила приватности?",
        "a": "Правила приватности позволяют настроить, какие данные собираются и обрабатываются. Администратор может создавать правила по типу данных, паттерну совпадения и действию (разрешить, заблокировать, маскировать)."
      },
      "howToApproveRequests": {
        "q": "Как одобрить заявки на вступление?",
        "a": "В панели администратора на вкладке «Организация» отображаются входящие заявки. Нажмите «Одобрить» для принятия или «Отклонить» для отказа. Одобренный пользователь сразу получит доступ к организации."
      },
      "howToContactSupport": {
        "q": "Как связаться со службой поддержки?",
        "a": "Перейдите в раздел «Поддержка» через боковое меню. Создайте новый чат, укажите тему обращения и опишите проблему. Вы также можете прикрепить скриншоты. Администратор ответит вам в этом же чате."
      },
      "howLongForReply": {
        "q": "Сколько ждать ответа от поддержки?",
        "a": "Обычно ответ приходит в течение рабочего дня. Статус вашего обращения отображается в списке чатов: «Открыт» — ожидает ответа, «Ответ» — получен ответ, «Закрыт» — вопрос решён."
      }
    }
  },
